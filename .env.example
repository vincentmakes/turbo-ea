# Turbo EA configuration
# Copy this file to .env and update the values before running docker compose.
# All deployment knobs live here so docker-compose.yml can stay free of inline
# defaults and .env remains the single source of truth.

# Image tag used by the GHCR images referenced in docker-compose.yml.
# Production compose is image-only and never builds. To run locally from source,
# use the dev override:
#   docker compose -f docker-compose.yml -f dev/docker-compose.dev.yml up -d --build
TURBO_EA_TAG=latest

# Optional Docker Compose profiles to start by default.
# Set to `ai` to always include Ollama, or `ai,mcp` to include both optional
# services without passing `--profile ...` on every docker compose command.
COMPOSE_PROFILES=

# Public HTTP port exposed by the bundled edge nginx service.
# Standard deployments should leave this at 80.
HOST_PORT=80
# Public HTTPS port exposed by the bundled edge nginx service when TLS is enabled.
# Standard deployments should leave this at 443.
TLS_HOST_PORT=443

# Runtime UID/GID for all containers. Default 1000:1000 matches the images.
# Override if your host filesystem expects different ownership (e.g. Unraid 99:100).
APP_UID=1000
APP_GID=1000

# Per-service memory limits. Override if you need to tighten or loosen them.
# Backend bundles the turbo-ea-capabilities wheel (capability + process +
# value-stream catalogues) plus the metamodel + optional demo seed at
# startup, and the inventory / catalogue pages pull large card lists +
# hold long-lived SSE connections at request time. Steady-state sits
# around 250–500 MB on x86 hosts; 2G gives comfortable headroom for
# request spikes (e.g. ?page_size=10000 inventory dumps, large bundled
# catalogue payloads) without OOM-killing the process under cgroup
# memory limits. Drop back to 1G if you've disabled SEED_DEMO/SEED_BPM/
# SEED_PPM and rarely use the catalogue browsers.
BACKEND_MEMORY_LIMIT=2G
FRONTEND_MEMORY_LIMIT=256M
MCP_MEMORY_LIMIT=256M

# PostgreSQL credentials for the bundled `db` service.
# The bundled stack expects POSTGRES_HOST=db by default.
POSTGRES_HOST=db
# Backend-to-Postgres TCP port.
POSTGRES_PORT=5432
# Database name created by the bundled Postgres image on first boot.
POSTGRES_DB=turboea
# Database user created by the bundled Postgres image on first boot.
POSTGRES_USER=turboea
# Password for the application database user.
POSTGRES_PASSWORD=changeme_use_a_strong_password

# Backend / application settings
# Generate a strong secret with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme_generate_with_python_c_import_secrets_print_secrets_token_urlsafe_64
# JWT access-token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Set to production, development, or another deployment label used by the app.
ENVIRONMENT=production

# Comma-separated list of allowed browser origins.
# In production, set this to your HTTPS domain, for example:
# ALLOWED_ORIGINS=https://ea.yourdomain.com
ALLOWED_ORIGINS=http://localhost

# Operational flags
# RESET_DB=true  -> drop all tables and recreate on next start
# SEED_DEMO=true -> load the full NexaTech demo dataset on first startup
# SEED_BPM=true  -> add BPM demo content to an existing demo environment
# SEED_PPM=true  -> add PPM demo content to an existing demo environment
RESET_DB=false
SEED_DEMO=false
SEED_BPM=false
SEED_PPM=false

# Email / SMTP (optional)
# SMTP server hostname. Leave empty to disable outbound mail.
SMTP_HOST=
# SMTP server port.
SMTP_PORT=587
# SMTP username, if authentication is required.
SMTP_USER=
# SMTP password, if authentication is required.
SMTP_PASSWORD=
# From-address used for outbound emails.
SMTP_FROM=noreply@turboea.local
# Whether to use STARTTLS / TLS for SMTP.
SMTP_TLS=true

# Email transport method: smtp_basic (default) | smtp_oauth | graph_api.
# Modern OAuth methods avoid storing mailbox passwords and keep working after
# Microsoft 365 / Google Workspace disable basic SMTP auth. The OAuth fields
# below are a DEDICATED email app registration (not the SSO one) — they can be
# set here or via Admin → Settings → Email. Secrets entered in the UI are
# encrypted at rest; values set here are read at startup.
EMAIL_METHOD=smtp_basic
# Identity provider for OAuth methods: microsoft | google
EMAIL_OAUTH_PROVIDER=microsoft
# Microsoft: directory (tenant) id; client (application) id + secret of the
# email app registration (needs the Mail.Send application permission).
EMAIL_OAUTH_TENANT_ID=
EMAIL_OAUTH_CLIENT_ID=
EMAIL_OAUTH_CLIENT_SECRET=
# graph_api: the mailbox Graph sends from (user principal name or object id).
EMAIL_GRAPH_SENDER=
# Optional overrides — leave empty to use sensible per-provider defaults.
EMAIL_OAUTH_SCOPE=
EMAIL_OAUTH_TOKEN_ENDPOINT=
# Google Workspace (smtp_oauth): service-account JSON key with domain-wide
# delegation enabled for the sender mailbox.
EMAIL_SERVICE_ACCOUNT_JSON=

# AI settings
# Option A: bundled Ollama
#   docker compose --profile ai up -d
#   AI_PROVIDER_URL=http://ollama:11434
#   AI_MODEL=gemma3:4b
#   AI_AUTO_CONFIGURE=true
#   OLLAMA_KEEP_ALIVE=-1
#
# Option B: external LLM / Ollama-compatible endpoint
#   AI_PROVIDER_URL=https://your-provider.example.com
#   AI_MODEL=your-model-name
#   AI_AUTO_CONFIGURE=true
#
# Search provider options: duckduckgo, google, searxng
# For Google, set AI_SEARCH_URL to API_KEY:CX
# For SearXNG, set AI_SEARCH_URL to your SearXNG base URL
AI_PROVIDER_URL=
AI_MODEL=
AI_SEARCH_PROVIDER=duckduckgo
AI_SEARCH_URL=
AI_AUTO_CONFIGURE=false

# ---------------------------------------------------------------------------
# Extension Store (optional)
# ---------------------------------------------------------------------------
# The extension store (Store tab on Admin → Extensions) works out of the
# box — the catalogue URL is built into the application, the tab is
# read-only (no account or token), and every download goes through the
# same signature verification as a manual upload. There is nothing to
# configure: air-gapped instances simply see a friendly offline hint and
# install from files instead.

# Memory limit for the optional bundled Ollama container.
OLLAMA_MEMORY_LIMIT=4G
# How long Ollama should keep the current model loaded in RAM after requests.
# Use -1 to keep it warm indefinitely, or durations like 30m / 24h.
OLLAMA_KEEP_ALIVE=5m

# MCP server public URLs.
# Internal MCP/backend wiring defaults for the bundled stack:
# Internal backend URL used by the MCP container in the bundled stack.
TURBO_EA_URL=http://backend:8000
# Port the MCP container listens on internally.
MCP_PORT=8001

# Enable the optional container with:
#   docker compose --profile mcp up -d
#
# Example production values:
#   TURBO_EA_PUBLIC_URL=https://ea.yourdomain.com
#   MCP_PUBLIC_URL=https://ea.yourdomain.com/mcp
#
# Add this callback to your SSO app registration when using HTTP MCP:
#   https://ea.yourdomain.com/mcp/oauth/callback
# Public base URL of the main Turbo EA app, used for OAuth redirects.
# The bundled edge nginx also derives its default `server_name` and forwarded
# protocol from this URL, so normal domain deployments do not need a separate
# nginx config override just to set the public hostname.
TURBO_EA_PUBLIC_URL=http://localhost
# Public base URL of the MCP endpoint.
MCP_PUBLIC_URL=http://localhost/mcp

# Optional direct TLS termination in the bundled edge nginx.
# Set TURBO_EA_TLS_ENABLED=true with HOST_PORT=80 and TLS_HOST_PORT=443 to
# serve both HTTP and HTTPS directly from the Turbo EA docker-compose stack
# with no override files. HTTP will redirect to HTTPS automatically.
#
# Set NGINX_ENABLE_IPV6=true only on hosts where Docker/nginx can actually bind
# IPv6 sockets. The default is false so the edge container still starts on
# IPv4-only hosts.
#
# If you use a companion certbot container or sibling letsencrypt folder,
# point TLS_CERTS_DIR at it:
#   TLS_CERTS_DIR=../certbot/certs
#   TURBO_EA_TLS_ENABLED=true
#   NGINX_ENABLE_IPV6=true
#   HOST_PORT=80
#   TLS_HOST_PORT=443
#   TURBO_EA_PUBLIC_URL=https://ea.yourdomain.com
#   MCP_PUBLIC_URL=https://ea.yourdomain.com/mcp
#
# The mounted directory is read-only inside the nginx container at /certs.
TURBO_EA_TLS_ENABLED=false
NGINX_ENABLE_IPV6=false
TLS_CERTS_DIR=./certs
TURBO_EA_TLS_CERT_FILE=cert.pem
TURBO_EA_TLS_KEY_FILE=key.pem

# DrawIO local development only.
# For non-Docker frontend development, set this in frontend/.env.development:
# VITE_DRAWIO_URL=https://embed.diagrams.net
