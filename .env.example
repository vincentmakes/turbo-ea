# Turbo EA Configuration
# Copy this file to .env and update values

# PostgreSQL — point to your existing PostgreSQL container
# On Unraid: use the container name or IP of your PostgreSQL instance
POSTGRES_HOST=PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=turboea
POSTGRES_USER=turboea
POSTGRES_PASSWORD=changeme_use_a_strong_password

# Backend
SECRET_KEY=changeme_generate_with_python_c_import_secrets_print_secrets_token_urlsafe_64
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=production

# CORS — comma-separated list of allowed origins
# ALLOWED_ORIGINS=https://your-domain.example.com

# Deployment — port exposed on the Unraid host
HOST_PORT=8920

# Demo data
# SEED_DEMO=true           # Pre-populate full NexaTech Industries demo dataset (first run only)
# SEED_BPM=true            # Add BPM demo data to an existing instance that already has the base demo

# AI / Ollama — two options:
#
# Option A: Bundled Ollama (easiest, no extra setup)
#   docker compose --profile ai up -d
#   AI_PROVIDER_URL=http://ollama:11434
#   AI_MODEL=gemma3:4b
#   AI_AUTO_CONFIGURE=true
#   # OLLAMA_MEMORY_LIMIT=4G          # (optional) override the default 4 GB RAM limit
#
# Option B: External Ollama (bring your own)
#   AI_PROVIDER_URL=http://host.docker.internal:11434   # or your Ollama host IP
#   AI_MODEL=gemma3:4b
#   AI_AUTO_CONFIGURE=true
#
# Models are cached in a Docker volume (turboea-ollama) — they persist across
# container rebuilds and restarts. The first startup pulls the model automatically.

# MCP Server — allows AI tools (Claude, Copilot, Cursor, etc.) to query EA data.
#
# ─── Option A: Remote (production, SSO-based) ───────────────────────────────
# Requires SSO to be enabled + MCP toggled on in admin settings.
#
#   docker compose --profile mcp up -d
#   TURBO_EA_PUBLIC_URL=https://your-domain.example.com
#   MCP_PUBLIC_URL=https://your-domain.example.com/mcp
#
# Then add the MCP server URL to your AI tool:
#   Claude Desktop → Settings → Connectors → Add custom connector → https://your-domain.example.com/mcp
#   VS Code → mcp.json → {"type": "http", "url": "https://your-domain.example.com/mcp/mcp"}
#
# IMPORTANT: Add the MCP callback redirect URI to your SSO app registration:
#   https://your-domain.example.com/mcp/oauth/callback
#
# ─── Option B: Local / stdio (testing, no HTTPS needed) ─────────────────────
# Runs MCP as a local process — Claude Desktop spawns it directly.
# No SSO or HTTPS required, authenticates with email/password.
#
#   pip install ./mcp-server
#
# Then add to your Claude Desktop config (claude_desktop_config.json):
#
#   {
#     "mcpServers": {
#       "turbo-ea": {
#         "command": "python",
#         "args": ["-m", "turbo_ea_mcp", "--stdio"],
#         "env": {
#           "TURBO_EA_URL": "http://192.168.1.131:8000",
#           "TURBO_EA_USERNAME": "your@email.com",
#           "TURBO_EA_PASSWORD": "your-password"
#         }
#       }
#     }
#   }
#
# The token refreshes automatically in the background.

# DrawIO — self-hosted by default (bundled in the Docker image).
# For local dev without Docker, create frontend/.env.development with:
#   VITE_DRAWIO_URL=https://embed.diagrams.net

# SECURITY NOTE (M9): Always deploy behind a TLS-terminating reverse proxy
# (e.g. Cloudflare, Caddy, nginx with Let's Encrypt, Traefik).
# Turbo EA does not terminate TLS itself — ensure HTTPS is enforced at
# the edge. Set ALLOWED_ORIGINS to your HTTPS domain accordingly.
