# Turbo EA configuration
# Copy this file to .env and update the values before running docker compose.
# All deployment knobs live here so docker-compose.yml can stay free of inline
# defaults and .env remains the single source of truth.

# Image tag used by the GHCR images referenced in docker-compose.yml.
# Production compose is image-only and never builds. To run locally from source,
# use the dev override:
#   docker compose -f docker-compose.yml -f dev/docker-compose.dev.yml up -d --build
TURBO_EA_TAG=latest

# Public host port exposed by the edge nginx service.
HOST_PORT=8920

# Runtime UID/GID for all containers. Default 1000:1000 matches the images.
# Override if your host filesystem expects different ownership (e.g. Unraid 99:100).
APP_UID=1000
APP_GID=1000

# Per-service memory limits. Override if you need to tighten or loosen them.
BACKEND_MEMORY_LIMIT=512M
FRONTEND_MEMORY_LIMIT=256M
MCP_MEMORY_LIMIT=256M

# PostgreSQL credentials for the bundled `db` service.
# The bundled stack expects POSTGRES_HOST=db by default.
POSTGRES_HOST=db
# Backend-to-Postgres TCP port.
POSTGRES_PORT=5432
# Database name created by the bundled Postgres image on first boot.
POSTGRES_DB=turboea
# Database user created by the bundled Postgres image on first boot.
POSTGRES_USER=turboea
# Password for the application database user.
POSTGRES_PASSWORD=changeme_use_a_strong_password

# Backend / application settings
# Generate a strong secret with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme_generate_with_python_c_import_secrets_print_secrets_token_urlsafe_64
# JWT access-token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Set to production, development, or another deployment label used by the app.
ENVIRONMENT=production

# Comma-separated list of allowed browser origins.
# In production, set this to your HTTPS domain, for example:
# ALLOWED_ORIGINS=https://ea.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8920

# Operational flags
# RESET_DB=true  -> drop all tables and recreate on next start
# SEED_DEMO=true -> load the full NexaTech demo dataset on first startup
# SEED_BPM=true  -> add BPM demo content to an existing demo environment
# SEED_PPM=true  -> add PPM demo content to an existing demo environment
RESET_DB=false
SEED_DEMO=false
SEED_BPM=false
SEED_PPM=false

# Email / SMTP (optional)
# SMTP server hostname. Leave empty to disable outbound mail.
SMTP_HOST=
# SMTP server port.
SMTP_PORT=587
# SMTP username, if authentication is required.
SMTP_USER=
# SMTP password, if authentication is required.
SMTP_PASSWORD=
# From-address used for outbound emails.
SMTP_FROM=noreply@turboea.local
# Whether to use STARTTLS / TLS for SMTP.
SMTP_TLS=true

# AI settings
# Option A: bundled Ollama
#   docker compose --profile ai up -d
#   AI_PROVIDER_URL=http://ollama:11434
#   AI_MODEL=gemma3:4b
#   AI_AUTO_CONFIGURE=true
#
# Option B: external LLM / Ollama-compatible endpoint
#   AI_PROVIDER_URL=https://your-provider.example.com
#   AI_MODEL=your-model-name
#   AI_AUTO_CONFIGURE=true
#
# Search provider options: duckduckgo, google, searxng
# For Google, set AI_SEARCH_URL to API_KEY:CX
# For SearXNG, set AI_SEARCH_URL to your SearXNG base URL
AI_PROVIDER_URL=
AI_MODEL=
AI_SEARCH_PROVIDER=duckduckgo
AI_SEARCH_URL=
AI_AUTO_CONFIGURE=false

# Memory limit for the optional bundled Ollama container.
OLLAMA_MEMORY_LIMIT=4G

# Optional NIST NVD API key for faster TurboLens CVE scans.
# Without a key, scans use the lower anonymous rate limit.
NVD_API_KEY=

# MCP server public URLs.
# Internal MCP/backend wiring defaults for the bundled stack:
# Internal backend URL used by the MCP container in the bundled stack.
TURBO_EA_URL=http://backend:8000
# Port the MCP container listens on internally.
MCP_PORT=8001

# Enable the optional container with:
#   docker compose --profile mcp up -d
#
# Example production values:
#   TURBO_EA_PUBLIC_URL=https://ea.yourdomain.com
#   MCP_PUBLIC_URL=https://ea.yourdomain.com/mcp
#
# Add this callback to your SSO app registration when using HTTP MCP:
#   https://ea.yourdomain.com/mcp/oauth/callback
# Public base URL of the main Turbo EA app, used for OAuth redirects.
TURBO_EA_PUBLIC_URL=http://localhost:8920
# Public base URL of the MCP endpoint.
MCP_PUBLIC_URL=http://localhost:8920/mcp

# DrawIO local development only.
# For non-Docker frontend development, set this in frontend/.env.development:
# VITE_DRAWIO_URL=https://embed.diagrams.net
